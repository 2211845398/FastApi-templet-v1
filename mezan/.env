# Application
NODE_ENV=development
PORT=3000
APP_URL=http://localhost:3000

#Docker
APP_PORT=8000
DB_PORT=5432

# Database (Postgres) - either use DATABASE_URL or individual parts
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=mezan_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=admin

DB_HOST=postgres

# Authentication / tokens
JWT_SECRET=replace_with_strong_jwt_secret
JWT_EXPIRES_IN=7d
SESSION_SECRET=replace_with_session_secret

# Caching / queue
REDIS_URL=redis://localhost:6379

# Email (SMTP)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your@email.example
SMTP_PASS=replace_smtp_password
EMAIL_FROM="Mezan <noreply@example.com>"

# Third-party services
STRIPE_SECRET_KEY=sk_test_replace
SENTRY_DSN=

# OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=

# Misc
ALLOW_ORIGIN=http://localhost:3000
LOG_LEVEL=info